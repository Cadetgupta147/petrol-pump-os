# Copy this file to .env and adjust for your setup.
# Never commit the real .env file — it's gitignored.
#
# Expo automatically loads EXPO_PUBLIC_-prefixed vars from .env at build time
# and inlines them into the app bundle (see
# https://docs.expo.dev/guides/environment-variables/). Only ever put
# non-secret, client-safe values behind this prefix — anything here is
# visible in the shipped app.

# Backend API base URL.
#   - Android emulator: http://10.0.2.2:3000  (10.0.2.2 = host machine's localhost,
#     from the emulator's point of view)
#   - iOS simulator:    http://localhost:3000
#   - Physical device via Expo Go, same Wi-Fi as your dev machine:
#                       http://<your-machine-LAN-IP>:3000
#     To find your machine's LAN IP, you don't need a separate ipconfig/ifconfig
#     lookup — `npx expo start` already prints it in its own terminal output /
#     QR-code screen, labeled something like "on your phone, connect to
#     exp://192.168.x.x:8081". Reuse that same IP here: swap the scheme to
#     http and the port to the backend's (3000), e.g. http://192.168.x.x:3000
EXPO_PUBLIC_API_BASE_URL="http://10.0.2.2:3000"
