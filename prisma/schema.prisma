// Initial schema derived from docs/master-plan.md Section 13.
// This is a starting point, not final — expand/adjust as each feature (Section 3-12) is built.
// Rule (see CLAUDE.md): never hand-edit a deployed schema — always `prisma migrate dev`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------- Enums ----------

enum Role {
  OWNER
  ACCOUNTANT
  MANAGER
  DSM
  READ_ONLY
}

enum PaymentType {
  CASH
  CARD
  UPI
  CREDIT
}

enum PaymentDirection {
  IN
  OUT
}

enum EntryChannel {
  WEB
  DSM_APP
}

enum EarningBasis {
  RUPEE
  LITRE
}

enum RedemptionType {
  CASH
  GIFT
  BOTH
}

enum BillAuditAction {
  CREATED
  EDITED
  DELETED
}

// Section 3.4A — informal (quick-added, unvetted) vs verified customers.
enum CustomerVerificationStatus {
  INFORMAL
  VERIFIED
}

// Section 3.4A — dealer-configurable credit limit enforcement.
enum CreditEnforcementMode {
  NOTIFY
  BLOCK
}

// ---------- Staff / Users / Roles ----------

model Staff {
  id             String          @id @default(cuid())
  name           String
  phone          String          @unique
  role           Role
  pinHash        String? // for DSM app PIN login
  // Web portal (Owner/Accountant/Manager/Read-only) login credential — Section 2.
  // Nullable: DSM-only staff authenticate via pinHash on the DSM app, not here.
  passwordHash   String?
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  billsEntered       Bill[]              @relation("BillEnteredBy")
  billsLastEdited    Bill[]              @relation("BillLastEditedBy")
  billsDeleted       Bill[]              @relation("BillDeletedBy")
  billAuditLogs      BillAuditLog[]
  meterReadings      MeterReading[]
  attendanceLogs     AttendanceLog[]
  cashCustodyLogs    CashCustodyLog[]
  dipReadings        DipReading[]
  densityLogs        DensityLog[]
}

model AttendanceLog {
  id        String   @id @default(cuid())
  staff     Staff    @relation(fields: [staffId], references: [id])
  staffId   String
  clockIn   DateTime
  clockOut  DateTime?
}

// ---------- Customers / Bills ----------

model Customer {
  id              String   @id @default(cuid())
  name            String
  phone           String?  @unique // KYC-lite identity — Section 6.1. Optional: quick-added
  // (informal) customers via bill-time quick-add (Section 3.4A) don't have a phone yet.
  // Postgres unique indexes treat multiple NULLs as distinct, so this stays safe.
  vehicleNumber   String?
  // Section 6.1/6.7 — human-friendly member id, e.g. "PUMP001-CUST-04521-6":
  // pump code + literal CUST + zero-padded sequence + Luhn check digit over
  // the sequence (for manual fallback entry when the card won't scan). This
  // is the ONLY thing the QR encodes. Generated app-side via
  // allocateQrMemberId() (customers/member-id.ts) from MemberIdCounter — no
  // DB default on purpose, so every create path must go through the
  // generator.
  qrMemberId      String   @unique
  loyaltyRateOverride Float? // per-customer override of default earning rate
  creditLimit     Float    @default(0) // Section 3.4 — max outstanding credit allowed
  // Section 3.4A — INFORMAL (quick-added at bill time, name + vehicle only) vs
  // VERIFIED (normal /customers onboarding, or an informal customer later
  // upgraded via PATCH). Visibility flag only — never itself blocks credit.
  verificationStatus CustomerVerificationStatus @default(VERIFIED)
  createdAt       DateTime @default(now())
  // Section 5 — customer JWT "kill switch". Embedded as a claim in every
  // customer JWT at issuance (CustomerAuthService.verifyOtp) and re-checked
  // against this live DB value on every customer-authenticated request
  // (CustomerJwtStrategy.validate). Bumping this value (no endpoint yet —
  // manual via Prisma Studio) invalidates every previously-issued token for
  // this customer at once, e.g. for a lost/stolen phone — a minimal "kill
  // all sessions" lever without building full refresh-token rotation.
  tokenVersion    Int      @default(0)

  bills                 Bill[]
  loyaltyTransactions   LoyaltyTransaction[]
  redemptionTransactions RedemptionTransaction[]
  payments              Payment[]
  creditAlerts          CreditLimitAlert[]
  otpRequests           CustomerOtp[]
}

// Section 5 — Credit Customer App login (phone + OTP). One row per OTP
// *request* (not an upsert-per-phone), so every send attempt is retained for
// rate-limiting/audit purposes — see CustomerAuthService for the actual
// rate-limit/lockout rules enforced against these rows:
//   - codeHash: bcrypt hash of the 6-digit OTP — the plaintext code is never
//     persisted, only handed to the OtpProvider for delivery and (in
//     NODE_ENV=development only) echoed back in the API response.
//   - customerId is nullable + resolved at request time on a best-effort
//     basis: a phone number can have a live OTP row before any Customer
//     record exists for it (verify() rejects that case with 404 rather than
//     silently auto-registering — see CustomerAuthService.verifyOtp).
//   - expiresAt + attemptCount implement expiry and lockout; consumedAt
//     makes a row single-use (set on successful verify, or once attemptCount
//     hits the lockout threshold).
model CustomerOtp {
  id           String    @id @default(cuid())
  phone        String
  customer     Customer? @relation(fields: [customerId], references: [id])
  customerId   String?
  codeHash     String
  expiresAt    DateTime
  attemptCount Int       @default(0)
  consumedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([phone, createdAt])
}

// Section 6.1/6.7 — monotonic sequence behind Customer.qrMemberId.
// Singleton row (id = 'singleton'), atomically incremented via
// update({ data: { lastSeq: { increment: 1 } } }) inside the customer-create
// transaction (see customers/member-id.ts), so two concurrent creates can
// never mint the same member number. Seeded by the
// human_friendly_member_ids migration at count(existing customers).
model MemberIdCounter {
  id      String @id
  lastSeq Int
}

model Bill {
  id                 String        @id @default(cuid())
  customer           Customer?     @relation(fields: [customerId], references: [id])
  customerId         String?
  vehicleNumber      String?
  customerName       String?
  amount             Float
  litres             Float
  productType        String
  rateApplied        Float
  // payment_type is no longer a single field — see Section 5A. A bill's payment
  // breakdown is derived from its BillPaymentLine rows (supports split payments).
  enteredBy          Staff         @relation("BillEnteredBy", fields: [enteredById], references: [id])
  enteredById         String
  entryChannel        EntryChannel
  timestamp           DateTime      @default(now())
  loyaltyPointsEarned Float         @default(0)
  loyaltyBasisUsed    EarningBasis?

  lastEditedBy       Staff?        @relation("BillLastEditedBy", fields: [lastEditedById], references: [id])
  lastEditedById     String?
  lastEditedAt       DateTime?
  deletedBy          Staff?        @relation("BillDeletedBy", fields: [deletedById], references: [id])
  deletedById        String?
  deletedAt          DateTime?

  loyaltyTransactions LoyaltyTransaction[]
  paymentLines        BillPaymentLine[]
  auditLogs           BillAuditLog[]
  creditAlerts        CreditLimitAlert[]
}

// Immutable audit trail for Bill — one row per create/edit/delete action,
// each holding a full snapshot. The CREATED row is never modified or
// removed, so the original entry's history survives every later edit.
model BillAuditLog {
  id            String           @id @default(cuid())
  bill          Bill             @relation(fields: [billId], references: [id])
  billId        String
  action        BillAuditAction
  performedBy   Staff            @relation(fields: [performedById], references: [id])
  performedById String
  performedAt   DateTime         @default(now())
  snapshot      Json
}

// Section 5A — a bill can be settled across multiple payment methods
// (e.g. half cash + half UPI, or "overpay by UPI, take cash change").
// Validation rule (enforce server-side, not just in the UI):
//   sum(amount where direction = IN) - sum(amount where direction = OUT) = bill.amount
model BillPaymentLine {
  id          String            @id @default(cuid())
  bill        Bill              @relation(fields: [billId], references: [id])
  billId      String
  paymentType PaymentType
  amount      Float
  direction   PaymentDirection // IN = money received, OUT = change given back
  createdAt   DateTime          @default(now())
}

// Section 3.4A — dealer-configurable credit limit enforcement mode + the
// default credit limit auto-applied to quick-added (informal) customers.
// Singleton pattern: only one row is ever really meant to matter — see
// CreditConfigService.getOrCreate().
model CreditConfig {
  id                         String                @id @default(cuid())
  enforcementMode            CreditEnforcementMode  @default(NOTIFY)
  defaultInformalCreditLimit Float                  @default(5000)
  updatedAt                  DateTime               @updatedAt
}

// Section 3.9 — Settings: business profile, GSTIN, pump license details.
// Same singleton pattern as CreditConfig — see
// BusinessProfileService.getOrCreate(). Every field is nullable/blank by
// default (unlike CreditConfig's defaults, there's no sane default for a
// business's own name or GSTIN) so a freshly-seeded pump doesn't show fake
// placeholder data before the Owner fills this in.
model BusinessProfile {
  id            String   @id @default(cuid())
  businessName  String?
  gstin         String?
  pumpLicenseNo String?
  address       String?
  updatedAt     DateTime @updatedAt
}

// Section 3.4A — one alert per bill that exceeded the customer's credit
// limit while CreditConfig.enforcementMode = NOTIFY (the bill still
// succeeds; this is the "dealer gets notified" side-effect). reminderRequested
// is null until the dealer acts on it (true/false) via PATCH /credit-alerts/:id;
// actually sending the reminder is Section 11, out of scope here.
model CreditLimitAlert {
  id                  String    @id @default(cuid())
  bill                Bill      @relation(fields: [billId], references: [id])
  billId              String
  customer            Customer  @relation(fields: [customerId], references: [id])
  customerId          String
  outstandingBefore   Float
  billNetCredit       Float
  creditLimit         Float
  overageAmount       Float
  reminderRequested   Boolean?
  reminderRequestedAt DateTime?
  createdAt           DateTime  @default(now())
}

// ---------- Meter Readings / Tanks ----------

model MeterReading {
  id         String   @id @default(cuid())
  nozzleId   String
  staff      Staff    @relation(fields: [staffId], references: [id])
  staffId    String
  openingReading Float
  closingReading Float?
  shiftStart DateTime @default(now())
  shiftEnd   DateTime?
  // Section 7.2 — product dispensed by this nozzle for this shift, captured
  // at open-shift time. There is no Nozzle master entity in this schema (see
  // apps/backend/src/tanks task spec), so this is how closeShift() resolves
  // which Tank to auto-deduct. Nullable so existing pre-Section-7 rows don't
  // need a migration backfill; OpenShiftDto requires it for all new shifts.
  productType String?
}

model Tank {
  id            String   @id @default(cuid())
  productType   String
  capacityLitres Float
  currentStockLitres Float
  lastDipReading Float?
  lastDipAt      DateTime?
  // Section 7.1 — OMC audit reference for the tank's calibration chart
  // (converts a physical dip-stick reading to litres). Not used in any
  // calculation here — informational/audit field only.
  calibrationChartRef String?

  densityLogs DensityLog[]
  dipReadings DipReading[]
}

// Section 7.1/7.2 — physical DIP stick reading, compared against the
// system-calculated running stock (Tank.currentStockLitres) to produce a
// variance report (shortage/excess flag). See tanks.service.ts for the
// variance formula and why it's derived from currentStockLitres rather than
// re-aggregated from PurchaseEntry/MeterReading history.
model DipReading {
  id                   String   @id @default(cuid())
  tank                 Tank     @relation(fields: [tankId], references: [id])
  tankId               String
  recordedBy           Staff    @relation(fields: [recordedById], references: [id])
  recordedById         String
  reading               Float    // physical stick measurement, litres
  systemStockAtReading Float    // Tank.currentStockLitres captured at the moment of this reading
  variance             Float    // systemStockAtReading - reading
  flagged              Boolean
  createdAt            DateTime @default(now())

  densityLogs          DensityLog[]
}

// Section 7.3 — density/quality check (density value in g/mL and, optionally,
// PPM/water-contamination reading), optionally linked to the delivery
// (PurchaseEntry) or the physical stock check (DipReading) that prompted it —
// both nullable because a density log isn't always tied to either. recordedBy
// reuses the same Staff actor pattern as DipReading.recordedBy rather than
// asking for a duplicate identity field when a density log rides along with
// a DIP reading (see DipReadingsService/TanksService.recordDipReading()).
model DensityLog {
  id              String         @id @default(cuid())
  tank            Tank           @relation(fields: [tankId], references: [id])
  tankId          String
  densityValue    Float
  ppmValue        Float?
  recordedBy      Staff          @relation(fields: [recordedById], references: [id])
  recordedById    String
  purchaseEntry   PurchaseEntry? @relation(fields: [purchaseEntryId], references: [id])
  purchaseEntryId String?
  dipReading      DipReading?    @relation(fields: [dipReadingId], references: [id])
  dipReadingId    String?
  // Out-of-range flag — see DENSITY_RANGE_BY_PRODUCT in density-logs.service.ts
  // for the placeholder acceptable-range map and what "unknown product" means.
  flagged         Boolean        @default(false)
  recordedAt      DateTime       @default(now())
}

// ---------- Walk-in Sales Aggregation (Section 8A) ----------
// Most walk-in customers never get an itemized Bill — only credit/loyalty
// customers or anyone who explicitly wants a receipt do. Everyone else is
// captured in aggregate here, reconciled against the shift's meter reading.

model ShiftSalesSummary {
  id                    String   @id @default(cuid())
  shiftId               String // ties back to the DSM's shift / MeterReading
  dsmId                 String
  nozzleId              String
  walkInLitres          Float
  walkInCashCollected    Float   @default(0)
  walkInUpiCollected     Float   @default(0)
  walkInCardCollected    Float   @default(0)
  expectedValue          Float // walk-in litres × rate in effect (Rate Master)
  variance                Float // expectedValue - (cash + upi + card actually collected)
  createdAt              DateTime @default(now())
}

// Section 8A.3 — PhonePe/Paytm Business merchant webhook events, used to
// auto-populate ShiftSalesSummary.walkInUpiCollected without manual DSM entry.
// Handler MUST be idempotent (dedupe on providerEventId) and verify the
// webhook signature before trusting the payload — see CLAUDE.md.
model UpiWebhookEvent {
  id               String   @id @default(cuid())
  provider         String // "phonepe" | "paytm"
  providerEventId  String   @unique // for idempotency — reject duplicates
  amount           Float
  receivedAt       DateTime
  matchedShiftId   String?
  matchedNozzleId  String?
  rawPayload       Json
  processedAt      DateTime @default(now())
}

// ---------- Purchases / Lubricants / Rate Master ----------

model PurchaseEntry {
  id           String   @id @default(cuid())
  supplierName String
  productType  String
  quantityLitres Float
  amount       Float
  // Section 7.1 — per-litre rate as stated on the invoice. Kept as its own
  // field rather than derived from amount/quantityLitres at read time, since
  // an invoice's stated rate can differ slightly from amount/quantity due to
  // rounding/taxes — deriving it would silently paper over that mismatch.
  ratePerLitre Float
  invoiceNo    String?
  tankerNo     String?
  invoiceImageUrl String? // OCR source image, Section 9
  ocrExtracted Boolean  @default(false)
  createdAt    DateTime @default(now())

  densityLogs  DensityLog[]
}

model LubricantItem {
  id        String @id @default(cuid())
  name      String
  stockQty  Int
  reorderAt Int
}

// Section 7.4 — Rate Master. Append-only history: corrections are new dated
// rows, not edits — there is deliberately no PATCH/DELETE (same philosophy
// as BillAuditLog's immutability). The unique constraint on
// (productType, effectiveFrom) prevents two rows from claiming the same
// effective date for the same product, which would make "the current rate"
// ambiguous at that date. See RateMasterService.getCurrentRate().
model RateHistory {
  id          String   @id @default(cuid())
  productType String
  rate        Float
  effectiveFrom DateTime

  @@unique([productType, effectiveFrom])
}

// ---------- Loyalty Program ----------

// Singleton (same pattern as CreditConfig — see LoyaltyService).
// Section 6.2 — earning side. earningBasis/defaultRate have NO schema
// defaults on purpose: the launch default basis and rate are open decisions
// (Section 17), so the dealer must set them explicitly via the API before
// any points can be calculated.
model LoyaltyConfig {
  id                     String         @id @default(cuid())
  earningBasis           EarningBasis
  defaultRate            Float
  // Section 6.4 — redemption side. Nullable because redemption policy at
  // launch (cash / gift / both, ratio, minimum) is itself still an open
  // decision (Section 17) — the earning side must be configurable without
  // forcing a guessed redemption setup.
  redemptionTypeAllowed  RedemptionType?
  // Section 6.4 — whether the customer picks cash/gift each redemption, or the
  // dealer has fixed a default. Only meaningful when redemptionTypeAllowed = BOTH.
  customerCanChooseRedemption Boolean       @default(false)
  defaultRedemptionMode       RedemptionType?
  cashRedemptionRatio    Float? // points -> currency conversion
  minRedeemablePoints    Int?
  updatedAt              DateTime       @updatedAt
}

model LoyaltyTransaction {
  id         String   @id @default(cuid())
  customer   Customer @relation(fields: [customerId], references: [id])
  customerId String
  bill       Bill?    @relation(fields: [billId], references: [id])
  billId     String?
  pointsDelta Float   // positive = earned, negative = redeemed
  reason     String
  createdAt  DateTime @default(now())
}

model GiftCatalogItem {
  id             String  @id @default(cuid())
  giftName       String
  imageUrl       String?
  pointsRequired Int
  stockQuantity  Int?
  activeFlag     Boolean @default(true)

  redemptions RedemptionTransaction[]
}

model RedemptionTransaction {
  id          String           @id @default(cuid())
  customer    Customer         @relation(fields: [customerId], references: [id])
  customerId  String
  giftItem    GiftCatalogItem? @relation(fields: [giftItemId], references: [id])
  giftItemId  String?
  redemptionType RedemptionType
  pointsSpent Int
  cashValue   Float?
  createdAt   DateTime         @default(now())
}

// ---------- Cash Custody ----------

// Section 8 — day-end 3-way cash split (bank / locker / taken home) plus
// running per-person carry-forward outstanding balance. One row per
// handledBy staff member per day-end entry (both the "close out today" and
// "bring back what I owe from before" steps are captured on the SAME row —
// see CashCustodyService for why broughtBackToday/cumulativeOutstandingBeforeToday
// live together with today's totals rather than as a separate entity).
//
// Replaces the pre-Section-8 stub (amountHeld/handedOverAt/reconciled) which
// didn't match the spec's 3-way-split + carry-forward model at all — dropped
// outright rather than kept alongside, since none of those three fields map
// cleanly onto the new shape and keeping them would just be dead columns.
model CashCustodyLog {
  id                                String   @id @default(cuid())
  date                              DateTime
  totalCashCollected                Float
  depositedToBank                   Float
  keptInLocker                      Float
  takenHome                         Float
  // Carry-forward chain (see CashCustodyService.create() for the resolution
  // + math): cumulativeOutstandingBeforeToday is resolved server-side from
  // this same staff member's most recent prior row's newOutstanding (0 if
  // none yet) — never client-supplied, so it can't be spoofed to erase a
  // debt. Named "cumulative", not "previous day", because it's the running
  // carried-through balance from the whole chain, not literally yesterday's
  // figure (a staff member's entries can be days apart, not just daily).
  cumulativeOutstandingBeforeToday  Float
  broughtBackToday                  Float
  newOutstanding                    Float
  handledBy                         Staff    @relation(fields: [handledById], references: [id])
  handledById                       String
  createdAt                         DateTime @default(now())
}

// ---------- Payments (bills + credit dues) ----------

model Payment {
  id         String      @id @default(cuid())
  customer   Customer    @relation(fields: [customerId], references: [id])
  customerId String
  amount     Float
  method     PaymentType
  reference  String? // gateway transaction id, once a payment gateway is chosen (see CLAUDE.md)
  createdAt  DateTime    @default(now())
}

// ---------- Tally Export ----------

model TallyExportLog {
  id            String   @id @default(cuid())
  exportedAt    DateTime @default(now())
  format        String // "xml" | "api"
  recordCount   Int
  status        String // "success" | "failed"
  // Section 10 — date range the export covered, logged so the "Tally export
  // log" report (Section 12) can show what period was exported/synced, not
  // just when the export was run.
  dateRangeFrom DateTime
  dateRangeTo   DateTime
}
