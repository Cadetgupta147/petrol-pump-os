// Initial schema derived from docs/master-plan.md Section 13.
// This is a starting point, not final — expand/adjust as each feature (Section 3-12) is built.
// Rule (see CLAUDE.md): never hand-edit a deployed schema — always `prisma migrate dev`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ---------- Enums ----------

enum Role {
  OWNER
  ACCOUNTANT
  MANAGER
  DSM
  READ_ONLY
}

enum PaymentType {
  CASH
  CARD
  UPI
  CREDIT
}

enum PaymentDirection {
  IN
  OUT
}

enum EntryChannel {
  WEB
  DSM_APP
}

enum EarningBasis {
  RUPEE
  LITRE
}

enum RedemptionType {
  CASH
  GIFT
  BOTH
}

enum BillAuditAction {
  CREATED
  EDITED
  DELETED
}

// Section 3.4A — informal (quick-added, unvetted) vs verified customers.
enum CustomerVerificationStatus {
  INFORMAL
  VERIFIED
}

// Section 3.4A — dealer-configurable credit limit enforcement.
enum CreditEnforcementMode {
  NOTIFY
  BLOCK
}

// ---------- Multi-tenancy (docs/multi-tenancy-plan.md) ----------

// The tenant root — one row per petrol pump business using this system.
// Phase 0.1 (see docs/multi-tenancy-plan.md progress log): every tenant
// table below gets a NULLABLE pumpId in this pass, backfilled to a single
// seeded "default" Pump — purely additive, no application code reads/filters
// on it yet. Phase 0.2 splits Staff/Customer into StaffAccount/
// StaffMembership and CustomerAccount/CustomerMembership (not done here).
// Phase 0.3 flips pumpId to required once the Phase 2 Prisma Client
// Extension guarantees every create path supplies it.
model Pump {
  id        String   @id @default(cuid())
  name      String
  // Human-readable prefix used in Customer.qrMemberId (e.g. "PUMP001-CUST-04521-6")
  // — replaces the old single-tenant PUMP_CODE env var (customers/member-id.ts).
  pumpCode  String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff                  Staff[]
  customers              Customer[]
  bills                  Bill[]
  billAuditLogs          BillAuditLog[]
  billPaymentLines       BillPaymentLine[]
  creditConfigs          CreditConfig[]
  businessProfiles       BusinessProfile[]
  creditLimitAlerts      CreditLimitAlert[]
  items                  Item[]
  nozzles                Nozzle[]
  meterReadings          MeterReading[]
  tanks                  Tank[]
  dipReadings            DipReading[]
  densityLogs            DensityLog[]
  shiftSalesSummaries    ShiftSalesSummary[]
  upiWebhookEvents       UpiWebhookEvent[]
  purchaseEntries        PurchaseEntry[]
  lubricantItems         LubricantItem[]
  rateHistories          RateHistory[]
  loyaltyConfigs         LoyaltyConfig[]
  loyaltyTransactions    LoyaltyTransaction[]
  giftCatalogItems       GiftCatalogItem[]
  redemptionTransactions RedemptionTransaction[]
  cashCustodyLogs        CashCustodyLog[]
  payments               Payment[]
  tallyExportLogs        TallyExportLog[]
  customerOtps           CustomerOtp[]
  memberIdCounters       MemberIdCounter[]
}

// ---------- Staff / Users / Roles ----------

// Phase 0.2 (docs/multi-tenancy-plan.md) — login identity for staff. One row
// per real person, holding the actual login credential. `Staff` below is now
// the per-pump MEMBERSHIP row — deliberately still named "Staff" (not
// "StaffMembership") so the many existing relations to it (Bill.enteredById,
// CashCustodyLog.handledById, MeterReading.staffId, etc.) don't need to
// change at all; only the credential-touching code
// (auth.service.ts/staff-management.service.ts) goes through this model.
model StaffAccount {
  id           String   @id @default(cuid())
  phone        String   @unique
  pinHash      String? // for DSM app PIN login
  // Web portal (Owner/Accountant/Manager/Read-only) login credential — Section 2.
  // Nullable: DSM-only staff authenticate via pinHash on the DSM app, not here.
  passwordHash String?
  // Authoritative identity name. Staff.name below is a denormalized COPY of
  // this (kept in sync on write by staff-management.service.ts) so the many
  // existing call sites that read Staff.name for display/audit purposes
  // don't need to join through account for every read.
  name         String
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships Staff[]
}

// Per-pump staff membership (see StaffAccount above for why this model kept
// its original name through the split). One row per (account, pump) — a
// person with memberships at two different pumps has two rows here, each
// with its own role/active flag, sharing one StaffAccount for login.
model Staff {
  id        String        @id @default(cuid())
  account   StaffAccount? @relation(fields: [accountId], references: [id])
  accountId String?
  pump      Pump          @relation(fields: [pumpId], references: [id])
  pumpId    String
  // Denormalized copy of StaffAccount.name — see the comment there.
  name      String
  role      Role
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  billsEntered           Bill[]           @relation("BillEnteredBy")
  billsLastEdited        Bill[]           @relation("BillLastEditedBy")
  billsDeleted           Bill[]           @relation("BillDeletedBy")
  billAuditLogs          BillAuditLog[]
  meterReadings          MeterReading[]   @relation("MeterReadingStaff")
  meterReadingsCorrected MeterReading[]   @relation("MeterReadingCorrectedBy")
  attendanceLogs         AttendanceLog[]
  cashCustodyLogs        CashCustodyLog[]
  dipReadings            DipReading[]
  densityLogs            DensityLog[]

  @@unique([accountId, pumpId])
}

model AttendanceLog {
  id       String    @id @default(cuid())
  staff    Staff     @relation(fields: [staffId], references: [id])
  staffId  String
  clockIn  DateTime
  clockOut DateTime?
}

// ---------- Customers / Bills ----------

// Phase 0.2 (docs/multi-tenancy-plan.md) — login identity for customers. One
// row per real phone number. `Customer` below is now the per-pump
// MEMBERSHIP row (kept its original name for the same reason `Staff` did —
// see that model's comment). Unlike StaffAccount, not every Customer gets
// one: an informal quick-added customer (Section 3.4A, no phone yet) has
// `accountId: null` until a phone is later added via the verification
// upgrade path, matching how `Customer.phone` was already nullable for
// exactly this reason before the split.
model CustomerAccount {
  id           String   @id @default(cuid())
  phone        String   @unique
  name         String?
  // Section 5 — customer JWT "kill switch", moved here from the membership
  // row: this is a property of the LOGIN SESSION, not of any one pump
  // relationship. Embedded as a claim in every customer JWT at issuance
  // (CustomerAuthService.verifyOtp) and re-checked against this live DB
  // value on every customer-authenticated request (CustomerJwtStrategy.validate).
  // Bumping this value invalidates every previously-issued token at once,
  // e.g. for a lost/stolen phone.
  tokenVersion Int      @default(0)
  createdAt    DateTime @default(now())

  memberships Customer[]
}

// Per-pump customer/loyalty membership (see CustomerAccount above for the
// naming rationale). One row per (account, pump) — a customer who's a
// loyalty/credit member at two different pumps has two rows here, each with
// its own points/credit/qrMemberId, sharing one CustomerAccount for login.
model Customer {
  id                  String                     @id @default(cuid())
  account             CustomerAccount?           @relation(fields: [accountId], references: [id])
  accountId           String?
  pump                Pump                       @relation(fields: [pumpId], references: [id])
  pumpId              String
  name                String
  // Denormalized copy of CustomerAccount.phone (kept in sync on write by
  // CustomersService) — NOT globally unique anymore now that one account can
  // have multiple per-pump membership rows; uniqueness lives on
  // CustomerAccount.phone instead. Nullable for the same informal quick-add
  // reason as before the split.
  phone               String?
  vehicleNumber       String?
  // Section 6.1/6.7 — human-friendly member id, e.g. "PUMP001-CUST-04521-6":
  // pump code + literal CUST + zero-padded sequence + Luhn check digit over
  // the sequence (for manual fallback entry when the card won't scan). This
  // is the ONLY thing the QR encodes. Generated app-side via
  // allocateQrMemberId() (customers/member-id.ts) from MemberIdCounter — no
  // DB default on purpose, so every create path must go through the
  // generator.
  qrMemberId          String                     @unique
  loyaltyRateOverride Float? // per-customer override of default earning rate
  creditLimit         Float                      @default(0) // Section 3.4 — max outstanding credit allowed
  // Section 3.4A — INFORMAL (quick-added at bill time, name + vehicle only) vs
  // VERIFIED (normal /customers onboarding, or an informal customer later
  // upgraded via PATCH). Visibility flag only — never itself blocks credit.
  verificationStatus  CustomerVerificationStatus @default(VERIFIED)
  createdAt           DateTime                   @default(now())

  bills                  Bill[]
  loyaltyTransactions    LoyaltyTransaction[]
  redemptionTransactions RedemptionTransaction[]
  payments               Payment[]
  creditAlerts           CreditLimitAlert[]
  otpRequests            CustomerOtp[]

  @@unique([accountId, pumpId])
}

// Section 5 — Credit Customer App login (phone + OTP). One row per OTP
// *request* (not an upsert-per-phone), so every send attempt is retained for
// rate-limiting/audit purposes — see CustomerAuthService for the actual
// rate-limit/lockout rules enforced against these rows:
//   - codeHash: bcrypt hash of the 6-digit OTP — the plaintext code is never
//     persisted, only handed to the OtpProvider for delivery and (in
//     NODE_ENV=development only) echoed back in the API response.
//   - customerId is nullable + resolved at request time on a best-effort
//     basis: a phone number can have a live OTP row before any Customer
//     record exists for it (verify() rejects that case with 404 rather than
//     silently auto-registering — see CustomerAuthService.verifyOtp).
//   - expiresAt + attemptCount implement expiry and lockout; consumedAt
//     makes a row single-use (set on successful verify, or once attemptCount
//     hits the lockout threshold).
//   - pumpId (Phase 0.1, nullable): customerId can't always resolve tenancy
//     (it's nullable), so this OTP row carries pumpId directly, resolved
//     from request context at send-time once that context exists (Phase 1/2)
//     — not yet wired up in this pass.
// pumpId is deliberately NOT required, unlike every other tenant table
// (Phase 0.3, docs/multi-tenancy-plan.md) — requestOtp() is a @Public()
// route with no JWT and Section 5's login flow allows sending an OTP to a
// phone that has NO Customer row yet (verifyOtp() cleanly 404s "not
// registered" rather than burning the caller's one valid OTP entry on a
// phone-existence check up front). There is genuinely no pump to attribute
// that OTP row to. When a matching Customer DOES already exist,
// requestOtp() best-effort resolves pumpId from that customer's own row —
// see the comment there. Either way, pumpId on THIS row is never
// load-bearing for the actual login decision: verifyOtp() always
// re-resolves pumpId fresh from a real Customer lookup for the JWT, never
// from here.
model CustomerOtp {
  id           String    @id @default(cuid())
  pump         Pump?     @relation(fields: [pumpId], references: [id])
  pumpId       String?
  phone        String
  customer     Customer? @relation(fields: [customerId], references: [id])
  customerId   String?
  codeHash     String
  expiresAt    DateTime
  attemptCount Int       @default(0)
  consumedAt   DateTime?
  createdAt    DateTime  @default(now())

  @@index([phone, createdAt])
}

// Section 6.1/6.7 — monotonic sequence behind Customer.qrMemberId.
// Singleton row (id = 'singleton'), atomically incremented via
// update({ data: { lastSeq: { increment: 1 } } }) inside the customer-create
// transaction (see customers/member-id.ts), so two concurrent creates can
// never mint the same member number. Seeded by the
// human_friendly_member_ids migration at count(existing customers).
// pumpId (Phase 0.1, nullable + unique): becomes the real per-pump singleton
// key once required (Phase 0.3) — one counter row per pump, not one global
// counter, so member-id sequences don't collide across pumps.
model MemberIdCounter {
  id      String @id
  pump    Pump   @relation(fields: [pumpId], references: [id])
  pumpId  String @unique
  lastSeq Int
}

model Bill {
  id                  String        @id @default(cuid())
  pump                Pump          @relation(fields: [pumpId], references: [id])
  pumpId              String
  customer            Customer?     @relation(fields: [customerId], references: [id])
  customerId          String?
  vehicleNumber       String?
  customerName        String?
  amount              Float
  litres              Float
  productType         String
  // Section 3.3.1 — which nozzle this bill was rung up against, if known.
  // Nullable: every historical bill and most current entry points don't
  // set it yet (this is schema/backend groundwork, not a completed UI
  // wire-up — see MeterReadingsService.checkVariance()'s comment for how it
  // improves the meter-vs-billed variance match once populated, and
  // CreateBillDto's comment for which entry points actually send it today).
  nozzle              Nozzle?       @relation(fields: [nozzleId], references: [id])
  nozzleId            String?
  rateApplied         Float
  // payment_type is no longer a single field — see Section 5A. A bill's payment
  // breakdown is derived from its BillPaymentLine rows (supports split payments).
  enteredBy           Staff         @relation("BillEnteredBy", fields: [enteredById], references: [id])
  enteredById         String
  entryChannel        EntryChannel
  timestamp           DateTime      @default(now())
  loyaltyPointsEarned Float         @default(0)
  loyaltyBasisUsed    EarningBasis?

  lastEditedBy   Staff?    @relation("BillLastEditedBy", fields: [lastEditedById], references: [id])
  lastEditedById String?
  lastEditedAt   DateTime?
  deletedBy      Staff?    @relation("BillDeletedBy", fields: [deletedById], references: [id])
  deletedById    String?
  deletedAt      DateTime?

  loyaltyTransactions LoyaltyTransaction[]
  paymentLines        BillPaymentLine[]
  auditLogs           BillAuditLog[]
  creditAlerts        CreditLimitAlert[]
}

// Immutable audit trail for Bill — one row per create/edit/delete action,
// each holding a full snapshot. The CREATED row is never modified or
// removed, so the original entry's history survives every later edit.
model BillAuditLog {
  id            String          @id @default(cuid())
  pump          Pump            @relation(fields: [pumpId], references: [id])
  pumpId        String
  bill          Bill            @relation(fields: [billId], references: [id])
  billId        String
  action        BillAuditAction
  performedBy   Staff           @relation(fields: [performedById], references: [id])
  performedById String
  performedAt   DateTime        @default(now())
  snapshot      Json
}

// Section 5A — a bill can be settled across multiple payment methods
// (e.g. half cash + half UPI, or "overpay by UPI, take cash change").
// Validation rule (enforce server-side, not just in the UI):
//   sum(amount where direction = IN) - sum(amount where direction = OUT) = bill.amount
model BillPaymentLine {
  id          String           @id @default(cuid())
  pump        Pump             @relation(fields: [pumpId], references: [id])
  pumpId      String
  bill        Bill             @relation(fields: [billId], references: [id])
  billId      String
  paymentType PaymentType
  amount      Float
  direction   PaymentDirection // IN = money received, OUT = change given back
  createdAt   DateTime         @default(now())
}

// Section 3.4A — dealer-configurable credit limit enforcement mode + the
// default credit limit auto-applied to quick-added (informal) customers.
// Singleton pattern: only one row is ever really meant to matter — see
// CreditConfigService.getOrCreate(). pumpId (Phase 0.1, nullable + unique):
// becomes the real per-pump singleton key once required (Phase 0.3).
model CreditConfig {
  id                         String                @id @default(cuid())
  pump                       Pump                  @relation(fields: [pumpId], references: [id])
  pumpId                     String                @unique
  enforcementMode            CreditEnforcementMode @default(NOTIFY)
  defaultInformalCreditLimit Float                 @default(5000)
  updatedAt                  DateTime              @updatedAt
}

// Section 3.9 — Settings: business profile, GSTIN, pump license details.
// Same singleton pattern as CreditConfig — see
// BusinessProfileService.getOrCreate(). Every field is nullable/blank by
// default (unlike CreditConfig's defaults, there's no sane default for a
// business's own name or GSTIN) so a freshly-seeded pump doesn't show fake
// placeholder data before the Owner fills this in. pumpId (Phase 0.1,
// nullable + unique): becomes the real per-pump singleton key once required
// (Phase 0.3).
model BusinessProfile {
  id            String   @id @default(cuid())
  pump          Pump     @relation(fields: [pumpId], references: [id])
  pumpId        String   @unique
  businessName  String?
  gstin         String?
  pumpLicenseNo String?
  address       String?
  updatedAt     DateTime @updatedAt
}

// Section 3.4A — one alert per bill that exceeded the customer's credit
// limit while CreditConfig.enforcementMode = NOTIFY (the bill still
// succeeds; this is the "dealer gets notified" side-effect). reminderRequested
// is null until the dealer acts on it (true/false) via PATCH /credit-alerts/:id;
// actually sending the reminder is Section 11, out of scope here.
model CreditLimitAlert {
  id                  String    @id @default(cuid())
  pump                Pump      @relation(fields: [pumpId], references: [id])
  pumpId              String
  bill                Bill      @relation(fields: [billId], references: [id])
  billId              String
  customer            Customer  @relation(fields: [customerId], references: [id])
  customerId          String
  outstandingBefore   Float
  billNetCredit       Float
  creditLimit         Float
  overageAmount       Float
  reminderRequested   Boolean?
  reminderRequestedAt DateTime?
  createdAt           DateTime  @default(now())
}

// ---------- Item Master ----------

enum ItemCategory {
  FUEL
  LUBRICANT
  OTHER
}

enum ItemUnit {
  LITRE
  KG
  PIECE
}

// Item Master — the single place an Owner/Manager/Accountant registers
// everything this pump sells (Petrol, Diesel, Speed, Urea/AdBlue, lubricant
// SKUs, and anything else), so every other module that needs "which
// product" stops relying on free-typed strings. Nozzle.itemId references
// this directly (Section 3.3.1). Tank/PurchaseEntry/RateHistory/Bill still
// store their own productType as a plain string rather than an itemId FK —
// deliberately NOT migrated in this slice, since those are already-stable,
// heavily-tested modules and a full migration is a larger, separate piece
// of work. Their web portal forms instead read GET /items to populate that
// same free-text field's dropdown/datalist, so in practice nobody types a
// product name by hand anywhere once it exists here — see each of those
// forms' own comments for the "reads from Item Master, writes a string"
// pattern.
model Item {
  id        String       @id @default(cuid())
  pump      Pump         @relation(fields: [pumpId], references: [id])
  pumpId    String
  name      String // e.g. "Petrol", "Diesel", "Speed 97", "Urea/AdBlue"
  category  ItemCategory
  unit      ItemUnit
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())

  nozzles Nozzle[]

  @@unique([pumpId, name])
}

// ---------- Meter Readings / Tanks ----------

// Section 3.3/4 — Nozzle master entity. Closes the gap this schema used to
// flag on MeterReading.productType ("no Nozzle master entity"). A dealer
// configures their pump's actual physical nozzle/meter count once, here —
// deliberately just a flat list scoped to the tenant pump (no fixed count,
// no hardcoded per-pump layout) since different pumps have different
// nozzle/gun counts and that must stay dealer-configurable, not baked into
// the schema. Every nozzle picker in the DSM app and web portal reads this
// list and renders a dropdown over it — nozzleId is never free-typed by a
// DSM again (see MeterReading.nozzleId below).
//
// startingReading is a ONE-TIME baseline, set when the nozzle is first
// configured (e.g. onboarding an already-running pump whose meter isn't at
// zero). It is read exactly once: the nozzle's very first-ever shift. Every
// shift after that carries the previous shift's closingReading forward as
// the new shift's openingReading instead — see
// MeterReadingsService.openShift()'s resolveOpeningReading() — which is
// also why startingReading must not be edited once any MeterReading exists
// against this nozzle (NozzlesService.update() enforces that).
//
// rolloverAt is nullable and opt-in: most modern electronic totalizers
// never roll over, so leaving it unset preserves closeShift()'s existing
// hard block on closingReading < openingReading. Dealers running older
// mechanical/electronic meters that DO physically reset to zero at a fixed
// digit count (e.g. 99999.99) set this once, and can then close a shift
// across that rollover via CloseShiftDto.meterRolledOver (see
// meter-readings.service.ts).
model Nozzle {
  id              String   @id @default(cuid())
  pump            Pump     @relation(fields: [pumpId], references: [id])
  pumpId          String
  label           String // dealer-defined display label shown in every dropdown, e.g. "N1", "P3"
  item            Item     @relation(fields: [itemId], references: [id])
  itemId          String
  startingReading Float // one-time baseline; superseded by carry-forward after the first shift
  rolloverAt      Float? // physical rollover point for meters that reset to 0; null = never rolls over
  isActive        Boolean  @default(true) // soft-disable instead of delete once a nozzle has reading history
  createdAt       DateTime @default(now())

  meterReadings MeterReading[]
  bills         Bill[]

  @@unique([pumpId, label])
}

model MeterReading {
  id               String    @id @default(cuid())
  pump             Pump      @relation(fields: [pumpId], references: [id])
  pumpId           String
  nozzle           Nozzle    @relation(fields: [nozzleId], references: [id])
  nozzleId         String
  // DB-level guarantee that a nozzle has at most one open shift at a time.
  // Set to nozzleId while the shift is open (closingReading null); set back
  // to null on close (see closeShift()). Postgres unique indexes allow
  // unlimited NULLs but at most one occurrence of any given non-null value,
  // so this closes the TOCTOU race a plain findFirst-then-create check
  // alone doesn't: of two near-simultaneous openShift() calls on the same
  // nozzle, at most one create() can succeed — the other hits a P2002
  // unique violation, translated to the same 409 ConflictException.
  openLockNozzleId String?   @unique
  staff            Staff     @relation("MeterReadingStaff", fields: [staffId], references: [id])
  staffId          String
  // Server-derived, never client-supplied — see openShift()'s
  // resolveOpeningReading(): carried forward from this nozzle's last closed
  // shift, or Nozzle.startingReading for its first-ever shift. A DSM (or any
  // caller) cannot set or edit this value directly.
  openingReading   Float
  closingReading   Float?
  // Both default to now() but are overridable by a non-DSM caller (Owner/
  // Accountant/Manager) for the "DSM app was down, entering this after the
  // fact" manual-entry fallback (Section 3.3) — see OpenShiftDto/
  // CloseShiftDto's shiftStart/shiftEnd fields and resolveAssignableActorId-
  // style role gating in MeterReadingsService. A DSM can never backdate
  // their own shift.
  shiftStart       DateTime  @default(now())
  shiftEnd         DateTime?
  // True when closeShift() was told this nozzle's meter physically rolled
  // over to zero mid-shift (CloseShiftDto.meterRolledOver). litresSold is
  // then computed as (nozzle.rolloverAt - openingReading) + closingReading
  // instead of the plain difference — see withComputedLitresSold().
  meterRolledOver  Boolean   @default(false)
  // Minimal audit trail for PATCH /meter-readings/:id/correct (Owner/
  // Accountant only) — not a full audit log table (contrast BillAuditLog):
  // a single before/after actor+timestamp pair is enough for "did someone
  // touch this after the fact", matching how other simpler entities here
  // (Tank) don't get a dedicated log table either.
  correctedBy      Staff?    @relation("MeterReadingCorrectedBy", fields: [correctedById], references: [id])
  correctedById    String?
  correctedAt      DateTime?
  // Section 7.2 — product dispensed by this nozzle for this shift, captured
  // at open-shift time from Nozzle's linked Item (also server-derived, not
  // client-supplied — see openShift()). This is how closeShift() resolves
  // which Tank to auto-deduct. Still nullable only because pre-Nozzle-master
  // legacy rows may have it null; every shift opened from here on always has it.
  productType      String?
}

model Tank {
  id                  String    @id @default(cuid())
  pump                Pump      @relation(fields: [pumpId], references: [id])
  pumpId              String
  productType         String
  capacityLitres      Float
  currentStockLitres  Float
  lastDipReading      Float?
  lastDipAt           DateTime?
  // Section 7.1 — OMC audit reference for the tank's calibration chart
  // (converts a physical dip-stick reading to litres). Not used in any
  // calculation here — informational/audit field only.
  calibrationChartRef String?

  densityLogs DensityLog[]
  dipReadings DipReading[]
}

// Section 7.1/7.2 — physical DIP stick reading, compared against the
// system-calculated running stock (Tank.currentStockLitres) to produce a
// variance report (shortage/excess flag). See tanks.service.ts for the
// variance formula and why it's derived from currentStockLitres rather than
// re-aggregated from PurchaseEntry/MeterReading history.
model DipReading {
  id                   String   @id @default(cuid())
  pump                 Pump     @relation(fields: [pumpId], references: [id])
  pumpId               String
  tank                 Tank     @relation(fields: [tankId], references: [id])
  tankId               String
  recordedBy           Staff    @relation(fields: [recordedById], references: [id])
  recordedById         String
  reading              Float // physical stick measurement, litres
  systemStockAtReading Float // Tank.currentStockLitres captured at the moment of this reading
  variance             Float // systemStockAtReading - reading
  flagged              Boolean
  createdAt            DateTime @default(now())

  densityLogs DensityLog[]
}

// Section 7.3 — density/quality check (density value in g/mL and, optionally,
// PPM/water-contamination reading), optionally linked to the delivery
// (PurchaseEntry) or the physical stock check (DipReading) that prompted it —
// both nullable because a density log isn't always tied to either. recordedBy
// reuses the same Staff actor pattern as DipReading.recordedBy rather than
// asking for a duplicate identity field when a density log rides along with
// a DIP reading (see DipReadingsService/TanksService.recordDipReading()).
model DensityLog {
  id              String         @id @default(cuid())
  pump            Pump           @relation(fields: [pumpId], references: [id])
  pumpId          String
  tank            Tank           @relation(fields: [tankId], references: [id])
  tankId          String
  densityValue    Float
  ppmValue        Float?
  recordedBy      Staff          @relation(fields: [recordedById], references: [id])
  recordedById    String
  purchaseEntry   PurchaseEntry? @relation(fields: [purchaseEntryId], references: [id])
  purchaseEntryId String?
  dipReading      DipReading?    @relation(fields: [dipReadingId], references: [id])
  dipReadingId    String?
  // Out-of-range flag — see DENSITY_RANGE_BY_PRODUCT in density-logs.service.ts
  // for the placeholder acceptable-range map and what "unknown product" means.
  flagged         Boolean        @default(false)
  recordedAt      DateTime       @default(now())
}

// ---------- Walk-in Sales Aggregation (Section 8A) ----------
// Most walk-in customers never get an itemized Bill — only credit/loyalty
// customers or anyone who explicitly wants a receipt do. Everyone else is
// captured in aggregate here, reconciled against the shift's meter reading.

model ShiftSalesSummary {
  id                  String   @id @default(cuid())
  pump                Pump     @relation(fields: [pumpId], references: [id])
  pumpId              String
  shiftId             String // ties back to the DSM's shift / MeterReading
  dsmId               String
  nozzleId            String
  walkInLitres        Float
  walkInCashCollected Float    @default(0)
  walkInUpiCollected  Float    @default(0)
  walkInCardCollected Float    @default(0)
  expectedValue       Float // walk-in litres × rate in effect (Rate Master)
  variance            Float // expectedValue - (cash + upi + card actually collected)
  createdAt           DateTime @default(now())
}

// Section 8A.3 — PhonePe/Paytm Business merchant webhook events, used to
// auto-populate ShiftSalesSummary.walkInUpiCollected without manual DSM entry.
// Handler MUST be idempotent (dedupe on providerEventId) and verify the
// webhook signature before trusting the payload — see CLAUDE.md. pumpId
// (Phase 0.1, nullable): not yet resolvable at webhook-receive time — Phase 3
// adds a pump-scoped webhook URL (/upi-webhook/:pumpId) that will set this.
model UpiWebhookEvent {
  id              String   @id @default(cuid())
  pump            Pump     @relation(fields: [pumpId], references: [id])
  pumpId          String
  provider        String // "phonepe" | "paytm"
  providerEventId String   @unique // for idempotency — reject duplicates
  amount          Float
  receivedAt      DateTime
  matchedShiftId  String?
  matchedNozzleId String?
  rawPayload      Json
  processedAt     DateTime @default(now())
}

// ---------- Purchases / Lubricants / Rate Master ----------

model PurchaseEntry {
  id              String   @id @default(cuid())
  pump            Pump     @relation(fields: [pumpId], references: [id])
  pumpId          String
  supplierName    String
  productType     String
  quantityLitres  Float
  amount          Float
  // Section 7.1 — per-litre rate as stated on the invoice. Kept as its own
  // field rather than derived from amount/quantityLitres at read time, since
  // an invoice's stated rate can differ slightly from amount/quantity due to
  // rounding/taxes — deriving it would silently paper over that mismatch.
  ratePerLitre    Float
  invoiceNo       String?
  tankerNo        String?
  invoiceImageUrl String? // OCR source image, Section 9
  ocrExtracted    Boolean  @default(false)
  createdAt       DateTime @default(now())

  densityLogs DensityLog[]
}

model LubricantItem {
  id        String @id @default(cuid())
  pump      Pump   @relation(fields: [pumpId], references: [id])
  pumpId    String
  name      String
  stockQty  Int
  reorderAt Int
}

// Section 7.4 — Rate Master. Append-only history: corrections are new dated
// rows, not edits — there is deliberately no PATCH/DELETE (same philosophy
// as BillAuditLog's immutability). The unique constraint on
// (pumpId, productType, effectiveFrom) prevents two rows from claiming the
// same effective date for the same product AT THE SAME PUMP, which would
// make "the current rate" ambiguous at that date. See
// RateMasterService.getCurrentRate().
model RateHistory {
  id            String   @id @default(cuid())
  pump          Pump     @relation(fields: [pumpId], references: [id])
  pumpId        String
  productType   String
  rate          Float
  effectiveFrom DateTime

  @@unique([pumpId, productType, effectiveFrom])
}

// ---------- Loyalty Program ----------

// Singleton (same pattern as CreditConfig — see LoyaltyService).
// Section 6.2 — earning side. earningBasis/defaultRate have NO schema
// defaults on purpose: the launch default basis and rate are open decisions
// (Section 17), so the dealer must set them explicitly via the API before
// any points can be calculated. pumpId (Phase 0.1, nullable + unique):
// becomes the real per-pump singleton key once required (Phase 0.3).
model LoyaltyConfig {
  id                          String          @id @default(cuid())
  pump                        Pump            @relation(fields: [pumpId], references: [id])
  pumpId                      String          @unique
  earningBasis                EarningBasis
  defaultRate                 Float
  // Section 6.4 — redemption side. Nullable because redemption policy at
  // launch (cash / gift / both, ratio, minimum) is itself still an open
  // decision (Section 17) — the earning side must be configurable without
  // forcing a guessed redemption setup.
  redemptionTypeAllowed       RedemptionType?
  // Section 6.4 — whether the customer picks cash/gift each redemption, or the
  // dealer has fixed a default. Only meaningful when redemptionTypeAllowed = BOTH.
  customerCanChooseRedemption Boolean         @default(false)
  defaultRedemptionMode       RedemptionType?
  cashRedemptionRatio         Float? // points -> currency conversion
  minRedeemablePoints         Int?
  updatedAt                   DateTime        @updatedAt
}

model LoyaltyTransaction {
  id          String   @id @default(cuid())
  pump        Pump     @relation(fields: [pumpId], references: [id])
  pumpId      String
  customer    Customer @relation(fields: [customerId], references: [id])
  customerId  String
  bill        Bill?    @relation(fields: [billId], references: [id])
  billId      String?
  pointsDelta Float // positive = earned, negative = redeemed
  reason      String
  createdAt   DateTime @default(now())
}

model GiftCatalogItem {
  id             String  @id @default(cuid())
  pump           Pump    @relation(fields: [pumpId], references: [id])
  pumpId         String
  giftName       String
  imageUrl       String?
  pointsRequired Int
  stockQuantity  Int?
  activeFlag     Boolean @default(true)

  redemptions RedemptionTransaction[]
}

model RedemptionTransaction {
  id             String           @id @default(cuid())
  pump           Pump             @relation(fields: [pumpId], references: [id])
  pumpId         String
  customer       Customer         @relation(fields: [customerId], references: [id])
  customerId     String
  giftItem       GiftCatalogItem? @relation(fields: [giftItemId], references: [id])
  giftItemId     String?
  redemptionType RedemptionType
  pointsSpent    Int
  cashValue      Float?
  createdAt      DateTime         @default(now())
}

// ---------- Cash Custody ----------

// Section 8 — day-end 3-way cash split (bank / locker / taken home) plus
// running per-person carry-forward outstanding balance. One row per
// handledBy staff member per day-end entry (both the "close out today" and
// "bring back what I owe from before" steps are captured on the SAME row —
// see CashCustodyService for why broughtBackToday/cumulativeOutstandingBeforeToday
// live together with today's totals rather than as a separate entity).
//
// Replaces the pre-Section-8 stub (amountHeld/handedOverAt/reconciled) which
// didn't match the spec's 3-way-split + carry-forward model at all — dropped
// outright rather than kept alongside, since none of those three fields map
// cleanly onto the new shape and keeping them would just be dead columns.
model CashCustodyLog {
  id                               String   @id @default(cuid())
  pump                             Pump     @relation(fields: [pumpId], references: [id])
  pumpId                           String
  date                             DateTime
  totalCashCollected               Float
  depositedToBank                  Float
  keptInLocker                     Float
  takenHome                        Float
  // Carry-forward chain (see CashCustodyService.create() for the resolution
  // + math): cumulativeOutstandingBeforeToday is resolved server-side from
  // this same staff member's most recent prior row's newOutstanding (0 if
  // none yet) — never client-supplied, so it can't be spoofed to erase a
  // debt. Named "cumulative", not "previous day", because it's the running
  // carried-through balance from the whole chain, not literally yesterday's
  // figure (a staff member's entries can be days apart, not just daily).
  cumulativeOutstandingBeforeToday Float
  broughtBackToday                 Float
  newOutstanding                   Float
  handledBy                        Staff    @relation(fields: [handledById], references: [id])
  handledById                      String
  createdAt                        DateTime @default(now())
}

// ---------- Payments (bills + credit dues) ----------

model Payment {
  id         String      @id @default(cuid())
  pump       Pump        @relation(fields: [pumpId], references: [id])
  pumpId     String
  customer   Customer    @relation(fields: [customerId], references: [id])
  customerId String
  amount     Float
  method     PaymentType
  reference  String? // gateway transaction id, once a payment gateway is chosen (see CLAUDE.md)
  createdAt  DateTime    @default(now())
}

// ---------- Tally Export ----------

model TallyExportLog {
  id            String   @id @default(cuid())
  pump          Pump     @relation(fields: [pumpId], references: [id])
  pumpId        String
  exportedAt    DateTime @default(now())
  format        String // "xml" | "api"
  recordCount   Int
  status        String // "success" | "failed"
  // Section 10 — date range the export covered, logged so the "Tally export
  // log" report (Section 12) can show what period was exported/synced, not
  // just when the export was run.
  dateRangeFrom DateTime
  dateRangeTo   DateTime
}
