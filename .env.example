# Copy this file to .env and fill in real values.
# Never commit the real .env file — it's gitignored.

# ---- Database (Supabase — get real values from your project's Connect dialog) ----
# DATABASE_URL: pooled connection (PgBouncer, port 6543) — used by the running app.
#   Requires ?pgbouncer=true so Prisma disables prepared statements; without it,
#   concurrent connections against the pooler can fail with "prepared statement
#   already exists" (42P05).
# DIRECT_URL: direct connection (port 5432) — used only for `prisma migrate`.
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@[pooler-host]:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# ---- App ----
NODE_ENV="development"
API_PORT=3000
PUMP_CODE="PUMP001"                # prefix for customer member IDs (Section 6.1/6.7), e.g. PUMP001-CUST-04521-6
JWT_SECRET=""                      # generate a long random string, do not reuse across environments; STAFF tokens only (web portal + DSM app)
CUSTOMER_JWT_SECRET=""              # separate long random string for the Credit Customer App phone+OTP login (Section 5) — MUST differ from JWT_SECRET so a customer token can never verify under the staff strategy or vice versa

# ---- CORS ----
# Comma-separated list of allowed origins for the web portal (and any other
# browser-based client). If unset in development, the backend defaults to
# Vite's default dev origin (http://localhost:5173). Add the deployed web
# portal's production domain here once it exists — no code change needed.
CORS_ALLOWED_ORIGINS="http://localhost:5173"

# ---- File / image storage (Cloudflare R2 or S3-compatible) ----
STORAGE_ENDPOINT=""
STORAGE_BUCKET=""
STORAGE_ACCESS_KEY_ID=""
STORAGE_SECRET_ACCESS_KEY=""

# ---- OCR (pick one — see docs/master-plan.md Section 9 and 17) ----
OCR_PROVIDER=""                    # "google" | "aws"
GOOGLE_CLOUD_VISION_API_KEY=""
AWS_TEXTRACT_ACCESS_KEY_ID=""
AWS_TEXTRACT_SECRET_ACCESS_KEY=""
AWS_TEXTRACT_REGION=""

# ---- Push notifications ----
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# ---- SMS fallback ----
# Also the not-yet-chosen delivery channel for Section 5's login OTP itself
# (distinct concern from the Section 11 notification fallback these vars
# were originally added for, but likely the same provider/keys once picked).
# Until a provider is wired in, CustomerAuthService only logs OTPs to the
# server console (apps/backend/src/customer-auth/otp/console-otp-provider.ts)
# — these vars are unused by that stub.
SMS_GATEWAY_API_KEY=""
SMS_GATEWAY_SENDER_ID=""

# ---- WhatsApp Business API (pick a provider — see Section 17) ----
WHATSAPP_PROVIDER=""               # "gupshup" | "interakt" | "meta"
WHATSAPP_API_KEY=""

# ---- Automated UPI capture at the counter (Section 8A.3) ----
# PhonePe/Paytm Business merchant webhook — NOT a payment gateway, just
# notifies your backend when money lands on your existing merchant QR.
UPI_MERCHANT_PROVIDER=""           # "phonepe" | "paytm"
UPI_WEBHOOK_SIGNING_SECRET=""      # used to verify incoming webhook payloads — do not skip this check

# ---- Payment gateway for in-app "Pay Now" / remote credit repayment ----
# (still open — see CLAUDE.md "open items". NOT the same as the UPI webhook
# above: this is for a customer paying remotely through the app, not a
# counter QR scan.)
# PAYMENT_GATEWAY_PROVIDER=""      # e.g. "razorpay" | "payu" | "cashfree"
# PAYMENT_GATEWAY_KEY_ID=""
# PAYMENT_GATEWAY_KEY_SECRET=""

# ---- Tally integration ----
TALLY_EXPORT_MODE="file"           # "file" | "api" — file export is the Phase 2 default
TALLY_COMPANY_NAME="Your Petrol Pump Pvt Ltd"  # must exactly match the company name as set up in Tally (SVCURRENTCOMPANY)

# ---- Error monitoring (add once chosen — see CLAUDE.md "known gaps") ----
# SENTRY_DSN=""

# ---- Mobile builds ----
# ANDROID_KEYSTORE_PATH=""
# ANDROID_KEYSTORE_PASSWORD=""
# APPLE_TEAM_ID=""
