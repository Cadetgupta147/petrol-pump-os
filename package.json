{
  "name": "petrol-pump-os",
  "private": true,
  "version": "0.0.1",
  "description": "Monorepo: backend API, web portal PWA, DSM app, credit customer app",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "prisma db seed",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "devDependencies": {
    "prisma": "^6.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcrypt": "^6.0.0"
  }
}
